<%- include('../partials/header') %>

<section class="page-hero food-hero">
  <div class="container">
    <p class="eyebrow">Cozinha amazônica</p>
    <h1>Gastronomia paraense</h1>
    <p>Em Belém, comer é uma forma de conhecer a floresta, os rios, os mercados e as tradições familiares.</p>
  </div>
</section>

<section class="section">
  <div class="container food-list">
    <% foods.forEach((food) => { %>
      <article class="food-row">
        <div class="food-row-image placeholder-image">
          <img src="/images/<%= food.image %>" alt="<%= food.name %> servido em Belém do Pará" loading="lazy">
        </div>
        <div>
          <p class="eyebrow">Sabor regional</p>
          <h2><%= food.name %></h2>
          <p><%= food.description %></p>
          <div class="info-box">
            <strong>Por que experimentar</strong>
            <span><%= food.reason %></span>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
