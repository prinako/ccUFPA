<%- include('../partials/header') %>

<section class="page-hero tips-hero">
  <div class="container">
    <p class="eyebrow">Planeje melhor</p>
    <h1>Dicas de viagem</h1>
    <p>Orientações práticas para aproveitar Belém com conforto, segurança e curiosidade.</p>
  </div>
</section>

<section class="section">
  <div class="container tips-grid">
    <% tips.forEach((tip) => { %>
      <article class="tip-card">
        <h2><%= tip.title %></h2>
        <p><%= tip.text %></p>
      </article>
    <% }) %>
  </div>
</section>

<section class="section section-soft">
  <div class="container split">
    <div>
      <p class="eyebrow">Antes de sair</p>
      <h2>Confirme informações operacionais</h2>
    </div>
    <p>Horários de atrações, travessias de barco, visitas guiadas e eventos podem mudar. Antes de cada passeio, consulte canais oficiais, hospedagem ou guias locais credenciados.</p>
  </div>
</section>

<%- include('../partials/footer') %>
