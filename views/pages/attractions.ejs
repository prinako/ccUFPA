<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">Passeios e pontos turísticos</p>
    <h1>Atrações de Belém</h1>
    <p>Conheça lugares que conectam história, natureza, fé, gastronomia e a vida ribeirinha da capital paraense.</p>
  </div>
</section>

<section class="section">
  <div class="container card-grid attractions-grid">
    <% attractions.forEach((item) => { %>
      <article class="image-card attraction-card">
        <div class="card-image placeholder-image">
          <img src="/images/<%= item.image %>" alt="Vista de <%= item.name %> em Belém do Pará" loading="lazy">
        </div>
        <div class="card-body">
          <h2><%= item.name %></h2>
          <p><%= item.description %></p>
          <div class="info-box">
            <strong>Dica para visitantes</strong>
            <span><%= item.tip %></span>
          </div>
          <ul class="meta-list">
            <li><%= item.hours %></li>
            <li><%= item.location %></li>
          </ul>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
