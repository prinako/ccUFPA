<%- include('../partials/header') %>

<section class="page-hero events-hero">
  <div class="container">
    <p class="eyebrow">Agenda cultural</p>
    <h1>Eventos em Belém</h1>
    <p>Fé, música, mercados, festivais e encontros gastronômicos movimentam a cidade ao longo do ano.</p>
  </div>
</section>

<section class="section">
  <div class="container timeline">
    <% events.forEach((event) => { %>
      <article class="timeline-item">
        <span class="timeline-dot"></span>
        <div>
          <h2><%= event.name %></h2>
          <p><%= event.description %></p>
          <div class="info-box">
            <strong>Dica</strong>
            <span><%= event.tip %></span>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
