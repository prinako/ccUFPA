<%- include('../partials/header') %>

<section class="page-hero contact-hero">
  <div class="container">
    <p class="eyebrow">Fale conosco</p>
    <h1>Contato</h1>
    <p>Envie dúvidas, sugestões ou pedidos de orientação para planejar sua visita a Belém.</p>
  </div>
</section>

<section class="section">
  <div class="container contact-grid">
    <div>
      <p class="eyebrow">Informações turísticas</p>
      <h2>Como podemos ajudar?</h2>
      <p>Este portal reúne conteúdo para visitantes interessados em cultura, gastronomia, eventos, transporte e atrações de Belém. Para informações oficiais, confirme detalhes com canais públicos de turismo e estabelecimentos locais.</p>
      <div class="contact-panel">
        <p><strong>Endereço:</strong> Centro de Atendimento ao Turista, Belém - PA.</p>
        <p><strong>E-mail:</strong> turismo@visitebelem.example</p>
        <p><strong>Redes sociais:</strong> @visitebelem</p>
      </div>
    </div>

    <form class="contact-form" method="post" action="/contato">
      <% if (typeof success !== 'undefined') { %>
        <p class="form-success" role="status"><%= success %></p>
      <% } %>
      <label for="name">Nome</label>
      <input id="name" name="name" type="text" autocomplete="name" required>

      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" autocomplete="email" required>

      <label for="message">Mensagem</label>
      <textarea id="message" name="message" rows="6" required></textarea>

      <button class="btn btn-primary" type="submit">Enviar mensagem</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
